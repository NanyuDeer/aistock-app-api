# 飞书企业自建应用邀请配置（用户需先加入企业才能 OAuth 授权）
# 二选一填写即可；若两个都填，前端会同时展示链接与二维码
FEISHU_ENTERPRISE_INVITE_LINK=https://your-feishu-invite-link
FEISHU_ENTERPRISE_INVITE_QR_URL=/your-qr-image-path.png

# ==================== Agent 反代 / 内网鉴权 ====================
# Python FastAPI Agent 服务地址。/api/agent/* 会反代到该地址（路径保留，SSE 流式透传）。
# AGENT_PY_URL 为主变量名；PYTHON_AGENT_URL 为兼容别名（二选一，AGENT_PY_URL 优先）。
AGENT_PY_URL=http://localhost:8000
# PYTHON_AGENT_URL=http://localhost:8000

# 内网鉴权 token：反代转发 /api/agent/* 时注入 X-Internal-Token 头，
# 同时校验 Python 回调 /internal/* 的 X-Internal-Token。需与 aistock-agent-py 的 INTERNAL_API_TOKEN 一致。
INTERNAL_API_TOKEN=change-me-in-production

# ==================== 双人财经播报 TTS ====================
# 生产推荐：火山引擎语音播客 API。前端只调用 Node API，凭证不得暴露到前端或提交 Git。
TTS_PROVIDER=volcengine_podcast
# 在火山语音控制台的“语音播客”服务中获取，必须与已开通播客服务的项目一致。
VOLCENGINE_PODCAST_APP_ID=your-volcengine-app-id
VOLCENGINE_PODCAST_ACCESS_TOKEN=your-volcengine-access-token
# 播客 WebSocket V3 协议固定值；通常无需修改。
VOLCENGINE_PODCAST_RESOURCE_ID=volc.service_type.10050
VOLCENGINE_PODCAST_APP_KEY=aGjiRDfUWi

# 生成后由 Node 写入并公开提供音频文件。
AGENT_AUDIO_DIR=D:\\ai_stock_app\\aistock-agent-py\\data\\audio

# 备选：Azure Speech 单次多音色 SSML。
# TTS_PROVIDER=azure
# AZURE_SPEECH_REGION=eastasia
# AZURE_SPEECH_KEY=your-azure-speech-key
