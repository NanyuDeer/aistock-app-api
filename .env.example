# ============================================
# AiStock App API — 环境变量模板
# 复制为 .env.development（本地开发）或 .env.production（服务器生产）
# .env.* 文件不提交 git，仅此模板提交
# ============================================

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/aistock
REDIS_URL=redis://:password@127.0.0.1:6379/9

# 安全
JWT_SECRET=your-jwt-secret
INTERNAL_API_TOKEN=your-internal-api-token

# 前端
FRONTEND_URL=http://localhost:5173
COOKIE_DOMAIN=localhost
CORS_ALLOW_ORIGIN=http://localhost:5173

# AI 模型（DeepSeek）
OPENAI_API_BASE_URL=https://api.deepseek.com/v1/chat/completions
OPENAI_API_KEY=sk-your-api-key
AI_BASE_URL=https://api.deepseek.com/v1/chat/completions
AI_API_KEY=sk-your-api-key
AI_MODEL=deepseek-v4-flash
EVA_MODEL=deepseek-v4-flash
OCR_MODEL=deepseek-v4-flash

CRAWLER_AI_BASE_URL=https://api.deepseek.com/v1
CRAWLER_AI_API_KEY=sk-your-api-key
CRAWLER_AI_MODEL=deepseek-v4-flash

# 微信
WECHAT_APPID=your-appid
WECHAT_SECRET=your-secret
WECHAT_TOKEN=your-token
WECHAT_TEMPLATE_LEADER=template-id
WECHAT_TEMPLATE_OUTBREAK=template-id
WECHAT_TEMPLATE_ID=template-id

# 飞书
FEISHU_APP_ID=your-app-id
FEISHU_APP_SECRET=your-app-secret
FEISHU_ENTERPRISE_INVITE_LINK=https://example.feishu.cn/invite/xxx
FEISHU_ENTERPRISE_INVITE_QR_URL=/feishu-invite-qr.png

# 股票数据
TUSHARE_TOKEN=your-token

# Agent Python 服务
AGENT_PY_URL=http://localhost:8080

# TTS
TTS_PROVIDER=volcengine_podcast
VOLCENGINE_PODCAST_APP_ID=your-app-id
VOLCENGINE_PODCAST_ACCESS_TOKEN=your-access-token
